import React, { useState, useEffect } from 'react';
import { Link } from 'react-router-dom';
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Loader2, Send, User, Image as ImageIcon } from "lucide-react";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";

export default function Messages() {
    const [conversations, setConversations] = useState([]);
    const [selectedConversation, setSelectedConversation] = useState(null);
    const [messages, setMessages] = useState([]);
    const [newMessage, setNewMessage] = useState("");
    const [loading, setLoading] = useState(true);
    const [currentUser, setCurrentUser] = useState(null);

    // Simulated data load
    useEffect(() => {
        const loadData = async () => {
            try {
                const fakeUser = {
                    id: 1,
                    name: "John Doe",
                    email: "john@example.com"
                };

                setCurrentUser(fakeUser);

                const fakeConversations = [
                    {
                        id: 1,
                        listing: {
                            title: "iPhone 11",
                            price: 5000,
                            images: ["https://via.placeholder.com/300"]
                        },
                        other_user_name: "Sarah",
                        last_message: {
                            content: "Is this still available?",
                            created_date: new Date()
                        },
                        messages: [
                            {
                                content: "Is this still available?",
                                created_by: "sarah@example.com",
                                created_date: new Date()
                            },
                            {
                                content: "Yes it is!",
                                created_by: "john@example.com",
                                created_date: new Date()
                            }
                        ]
                    }
                ];

                setConversations(fakeConversations);
            } catch (err) {
                console.error(err);
            } finally {
                setLoading(false);
            }
        };

        loadData();
    }, []);

    const openConversation = (conv) => {
        setSelectedConversation(conv);
        setMessages(conv.messages);
    };

    const sendMessage = (e) => {
        e.preventDefault();
        if (!newMessage.trim()) return;

        const message = {
            content: newMessage,
            created_by: currentUser.email,
            created_date: new Date()
        };

        setMessages(prev => [...prev, message]);
        setNewMessage("");
    };

    if (loading) {
        return (
            <div className="flex justify-center p-12">
                <Loader2 className="animate-spin" />
            </div>
        );
    }

    return (
        <div className="bg-white rounded-xl border min-h-[600px] flex overflow-hidden">

            {/* Sidebar */}
            <div className={`w-full md:w-1/3 border-r ${selectedConversation ? 'hidden md:flex' : ''}`}>
                <div className="p-4 border-b">
                    <h2 className="font-bold text-lg">Messages</h2>
                </div>

                {conversations.length === 0 ? (
                    <div className="p-6 text-center text-gray-400">
                        No conversations yet
                    </div>
                ) : (
                    conversations.map((conv, i) => (
                        <div
                            key={i}
                            onClick={() => openConversation(conv)}
                            className="p-4 border-b cursor-pointer hover:bg-gray-50"
                        >
                            <div className="flex gap-3">
                                <div className="w-12 h-12 bg-gray-200 rounded overflow-hidden">
                                    {conv.listing.images?.[0] ? (
                                        <img src={conv.listing.images[0]} className="w-full h-full object-cover" />
                                    ) : (
                                        <ImageIcon className="m-3 text-gray-400" />
                                    )}
                                </div>

                                <div className="flex-1">
                                    <h3 className="font-semibold">{conv.listing.title}</h3>
                                    <p className="text-sm text-gray-500">{conv.other_user_name}</p>
                                    <p className="text-sm text-gray-400 truncate">{conv.last_message.content}</p>
                                </div>
                            </div>
                        </div>
                    ))
                )}
            </div>

            {/* Chat */}
            <div className={`flex-1 flex flex-col ${!selectedConversation ? 'hidden md:flex' : ''}`}>

                {selectedConversation ? (
                    <>
                        {/* Header */}
                        <div className="p-4 border-b flex items-center justify-between">
                            <div className="flex items-center gap-3">
                                <Avatar>
                                    <AvatarImage src={selectedConversation.listing.images?.[0]} />
                                    <AvatarFallback><User /></AvatarFallback>
                                </Avatar>

                                <div>
                                    <h3 className="font-bold">{selectedConversation.listing.title}</h3>
                                    <p className="text-xs text-gray-500">
                                        R{selectedConversation.listing.price} • {selectedConversation.other_user_name}
                                    </p>
                                </div>
                            </div>

                            <Link to="/listing">
                                <Button size="sm" variant="outline">View</Button>
                            </Link>
                        </div>

                        {/* Messages */}
                        <div className="flex-1 p-4 overflow-y-auto space-y-3 bg-gray-50">
                            {messages.map((msg, i) => {
                                const isMe = msg.created_by === currentUser.email;

                                return (
                                    <div key={i} className={`flex ${isMe ? 'justify-end' : 'justify-start'}`}>
                                        <div className={`px-4 py-2 rounded-xl text-sm ${
                                            isMe ? 'bg-indigo-600 text-white' : 'bg-white border'
                                        }`}>
                                            {msg.content}
                                        </div>
                                    </div>
                                );
                            })}
                        </div>

                        {/* Input */}
                        <form onSubmit={sendMessage} className="p-3 border-t flex gap-2">
                            <Input
                                value={newMessage}
                                onChange={(e) => setNewMessage(e.target.value)}
                                placeholder="Type a message..."
                            />
                            <Button type="submit" disabled={!newMessage.trim()}>
                                <Send size={16} />
                            </Button>
                        </form>
                    </>
                ) : (
                    <div className="flex-1 flex items-center justify-center text-gray-400">
                        Select a conversation
                    </div>
                )}
            </div>
        </div>
    );
}
